# --- App ---
APP_ENV=production
APP_SECRET_KEY=change-me-32-chars-minimum-please-rotate
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7
LOGIN_LOCK_THRESHOLD=5
LOGIN_LOCK_WINDOW_SEC=300
LOGIN_LOCK_DURATION_SEC=900
DEFAULT_LOCALE=en

# --- Database ---
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=burglar
MYSQL_USER=burglar
MYSQL_PASSWORD=change-me-app
MYSQL_HOST=mysql
MYSQL_PORT=3306

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Camera credentials encryption ---
# Fernet key (44 char urlsafe base64). Generate once and keep this stable.
CAMERA_CRED_KEY_FILE=/run/secrets/camera_cred.key

# --- Detection defaults ---
DEFAULT_DWELL_LIMIT_SEC=180
DEFAULT_COUNT_LIMIT=3
DEFAULT_COUNT_WINDOW_SEC=86400
PERSON_GID_TTL_SEC=86400
RING_BUFFER_SEC=10
TARGET_FPS=8
REID_THRESHOLD=0.35

# --- Storage ---
CLIPS_DIR=/data/clips
SNAPS_DIR=/data/snaps
BACKUP_DIR=/var/lib/burglar/backup
BACKUP_RETENTION_DAYS=30

# --- Worker placement ---
WORKER_GPU_DEVICE=0
WORKER_MAX_CAMERAS=8

# --- Public URL (used in CORS) ---
PUBLIC_ORIGIN=https://burglar.local

# --- Dev-only flags ---
# Skip RTSP probe on /api/cameras/test and on camera create/update.
# Lets you exercise the Add Camera UI without a real camera. Never set in prod.
DEV_SKIP_RTSP_PROBE=false
